{
	"manifest_version": 3,
	"name": "Vim for Google Docs",
	"version": "1.0",
	"author": "Quantier, LLC",
	"description": "Use Vim keybindings in Google Docs, zero setup required.",
	"icons": {
		"16": "icons/16x16.png",
		"32": "icons/32x32.png",
		"48": "icons/48x48.png",
		"128": "icons/128x128.png"
	},
	"content_scripts": [
		{
			"matches": ["https://extensionpay.com/*"],
			"js": ["dist/ExtPay.js"],
			"run_at": "document_start"
		},
		{
			"matches": ["*://*.google.com/*document/d/*/edit*"],
			"js": ["dist/ExtPay.js", "dist/bundle.js"]
		}
	],
	"background": {
		"service_worker": "background.js"
	},
	"permissions": ["storage"],
	"action": { "default_popup": "popup.html" }
}
