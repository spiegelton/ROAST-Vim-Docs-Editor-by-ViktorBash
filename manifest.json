{
  "manifest_version": 3,
  "name": "Vim for Google Docs",
  "version": "1.0",
  "description": "Use Vim keybindings in Google Docs, zero setup required.",
  "icons": 
    {
      "16": "icons/16x16.png",
      "32": "icons/32x32.png",
      "48": "icons/48x48.png",
      "128": "icons/128x128.png"
    },
  "content_scripts": [
    {
      "matches": [
        "*://*.google.com/*document/d/*/edit*"
      ],
      "js": [
        "dist/bundle.js"
      ]
    }
  ]
}

